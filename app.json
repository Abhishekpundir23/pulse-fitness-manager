{
  "expo": {
    "name": "Pulse Fitness Manager",
    "slug": "pulse-fitness-manager",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/pulse-icon-1024.png",
    "scheme": "pulsefitness",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "in.parsewave.pulsefitness",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#0B1320",
        "foregroundImage": "./assets/images/pulse-icon-1024.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/pulse-icon-1024.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0B1320",
          "dark": {
            "backgroundColor": "#0B1320"
          }
        }
      ],
      "expo-sqlite",
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Pulse Fitness Manager to select member profile photos.",
          "cameraPermission": "Allow Pulse Fitness Manager to take member profile photos.",
          "microphonePermission": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d5e51107-04f6-4556-9408-c0a04e26ca9f"
      }
    },
    "owner": "abhi2302"
  }
}
